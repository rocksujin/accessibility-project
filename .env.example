# ---- Server (server/index.ts) ----
# Anthropic key for the /api/explain endpoint.
ANTHROPIC_API_KEY=sk-ant-...

# Port the scan server listens on (host platforms usually inject this).
PORT=3001

# Comma-separated CORS allowlist of frontend origins. Default "*" allows any.
# In production, lock this to your deployed site, e.g.:
# ALLOWED_ORIGINS=https://<your-username>.github.io
ALLOWED_ORIGINS=*

# ---- Frontend (Vite, build-time) ----
# Backend origin the SPA calls. Leave UNSET in dev (Vite proxies /api to :3001).
# Set this when building for static hosting so POSTs hit the real backend
# instead of returning 405 from the static host:
# VITE_API_BASE=https://kayai-scan.onrender.com
