# Production build config (read by `vite build` / `npm run deploy`).
# VITE_API_BASE is baked into the client bundle so the deployed SPA on
# GitHub Pages calls the real backend instead of POSTing to the static host
# (which returns 405). Not a secret — it's a public URL visible in the bundle.
#
# Dev (`npm run dev`) ignores this file and leaves VITE_API_BASE unset, so
# Vite proxies /api to localhost:3001 (see vite.config.ts).
VITE_API_BASE=https://accessibility-project.onrender.com
